{
  "pipeline": "approval",
  "trackerName": "PM approval ratings",
  "dataUrl": "https://docs.google.com/spreadsheets/d/e/2PACX-1vQY797SnNrQzpin7dGAKW7PLLUOd0eSzQJV1-BxLbtZQnKg_H7LtIdkzTYFxlTaqBeYXVDQ4BPJnXhR/pub?gid=1620180028&single=true&output=csv",

  "columns": {
    "date":     0,
    "pollster": 1,
    "leader":   2
  },

  "smoothing": {
    "bandwidthDays": 90,
    "minPollsInWindow": 3,
    "bootstrapIterations": 200
  },

  "skipPollsterPatterns": [],

  "leaders": [
    { "name": "Thatcher", "bandwidthDays": 180, "matchName": "Margaret Thatcher", "approveCol": 5,  "disapproveCol": 6,  "color": "#0087DC", "inOfficeSince": "04/05/1979" },
    { "name": "Major", "bandwidthDays": 180,   "matchName": "John Major",         "approveCol": 7,  "disapproveCol": 8,  "color": "#0087DC", "inOfficeSince": "28/11/1990" },
    { "name": "Blair", "bandwidthDays": 180,   "matchName": "Tony Blair",         "approveCol": 9,  "disapproveCol": 10, "color": "#E4003B", "inOfficeSince": "02/05/1997" },
    { "name": "Brown",    "matchName": "Gordon Brown",       "approveCol": 11, "disapproveCol": 12, "color": "#E4003B", "inOfficeSince": "27/06/2007" },
    { "name": "Cameron",  "matchName": "David Cameron",      "approveCol": 13, "disapproveCol": 14, "color": "#0087DC", "inOfficeSince": "11/05/2010" },
    { "name": "May",      "matchName": "Theresa May",        "approveCol": 15, "disapproveCol": 16, "color": "#0087DC", "inOfficeSince": "13/07/2016" },
    { "name": "Johnson",  "matchName": "Boris Johnson",      "approveCol": 17, "disapproveCol": 18, "color": "#0087DC", "inOfficeSince": "24/07/2019" },
    { "name": "Truss", "bandwidthDays": 10,   "matchName": "Liz Truss",          "approveCol": 19, "disapproveCol": 20, "color": "#0087DC", "inOfficeSince": "06/09/2022" },
    { "name": "Sunak", "bandwidthDays": 40,   "matchName": "Rishi Sunak",        "approveCol": 21, "disapproveCol": 22, "color": "#0087DC", "inOfficeSince": "25/10/2022" },
    { "name": "Starmer", "bandwidthDays": 40, "matchName": "Keir Starmer",       "approveCol": 3,  "disapproveCol": 4,  "color": "#E4003B", "inOfficeSince": "05/07/2024" }
  ],

  "output": {
    "linesCsvPath": "trackers/ldrXXallPMs/data/approval-lines.csv",
    "daysCsvPath":  "trackers/ldrXXallPMs/data/approval-days.csv",
    "rawCsvPath":   "trackers/ldrXXallPMs/data/approval-raw.csv",
    "datawrapperLinesChartId": "mj4aT",
    "datawrapperDaysChartId":  "TNsXR"
  }
}
