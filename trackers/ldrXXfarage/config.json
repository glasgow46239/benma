{
  "pipeline": "smooth",
  "trackerName": "Leadership view",
  "dataUrl": "https://docs.google.com/spreadsheets/d/e/2PACX-1vRUV0qTNO_TaH0vyqyhqCgdo76BxF8W3oMfhLbgTucogF15cuT_EjGhzvCCynZ9FGe2EjrS5sXLE8ga/pub?gid=1873886643&single=true&output=csv",
  "subgroupColumn": 11,
  "smoothing": {
    "bandwidthDays": 40,
    "minPollsInWindow": 2,
    "bootstrapIterations": 200
  },
  "skipPollsterPatterns": [],
  "subgroups": [
    { "name": "65+",     "value": "65+",     "barIncludeOther": true, "barParties": ["Positive", "Negative", "Unsure"], "bandwidthDays": 80, "minPollsInWindow": 2 },
    { "name": "50-64",   "value": "50-64",   "barIncludeOther": true, "barParties": ["Positive", "Negative", "Unsure"], "bandwidthDays": 80, "minPollsInWindow": 2 },
    { "name": "35-49",   "value": "35-49",   "barIncludeOther": true, "barParties": ["Positive", "Negative", "Unsure"], "bandwidthDays": 80, "minPollsInWindow": 2 },
    { "name": "18-34",   "value": "18-34",   "barIncludeOther": true, "barParties": ["Positive", "Negative", "Unsure"], "bandwidthDays": 80, "minPollsInWindow": 2 },
    { "name": "Overall", "value": "overall", "barIncludeOther": true, "barParties": ["Positive", "Negative", "Unsure"], "bandwidthDays": 80, "minPollsInWindow": 2 }
  ],
  "historicalSeries": {
    "url": "https://raw.githubusercontent.com/glasgow46239/benma/main/trackers/vi19all/data/line-{subgroup}.csv",
    "labelSuffix": " (19-24)",
    "parties": ["Positive", "Negative", "Unsure"],
    "matchSubgroup": true
  },
  "parties": [
    { "name": "Positive",    "col": 2,  "color": "#009076", "includeInLine": true, "includeInBar": true },
    { "name": "Negative",    "col": 3,  "color": "#d45a49", "includeInLine": true, "includeInBar": true },
    { "name": "Unsure",   "col": 4,  "color": "#D3D3D3", "includeInLine": true, "includeInBar": true }
  ],
  "referenceElection": {
    "label": "2024 general election",
    "date": "04/07/2024",
    "results": {
      "Con": 24, "Lab": 35, "LDem": 13, "Grn": 7, "Reform": 15
    }
  },
  "output": {
    "lineJsonPath": "trackers/ldrXXfarage/data/line.json",
    "barCsvPath":   "trackers/ldrXXfarage/data/bar.csv",
    "lineCsvPath":  "trackers/ldrXXfarage/data/line.csv",
    "subgroups": {
      "65+":     { "datawrapperLineChartId": "", "datawrapperBarChartId": "" },
      "50-64":   { "datawrapperLineChartId": "", "datawrapperBarChartId": "" },
      "35-49":   { "datawrapperLineChartId": "", "datawrapperBarChartId": "" },
      "18-34":   { "datawrapperLineChartId": "", "datawrapperBarChartId": "" },
      "overall": { "datawrapperLineChartId": "", "datawrapperBarChartId": "" }
    }
  }
}
